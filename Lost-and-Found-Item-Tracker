# This function integrates with an external API to get the current date and time
# Falls back to system date if API is unavailable
def get_current_datetime():
    try:
        # Try World Time API with timeout
        response = requests.get("http://worldtimeapi.org/api/timezone/America/New_York", timeout=5)
        if response.status_code == 200:
            data = response.json()
            datetime_str = data['datetime'][:10]  # Extract date part YYYY-MM-DD
            return datetime_str
    except requests.exceptions.Timeout:
        print("API request timed out, using system date")
    except requests.exceptions.ConnectionError:
        print("Could not connect to API, using system date")
    except Exception as e:
        print(f"Error fetching datetime: {e}")
    
    # Fallback to system date
    from datetime import datetime
    return datetime.now().strftime("%Y-%m-%d")

# File names where data will be stored
lost_file = "lost_items.csv"
found_file = "found_items.csv"

# This function ensures both CSV files exist before the program runs
# If they don't exist, it creates them with the correct columns
def initialize_files():
    try:
        pd.read_csv(lost_file)
    except FileNotFoundError:
        # Create a new file for lost items with required columns
        pd.DataFrame(columns=["description", "location", "date", "matricula"]).to_csv(lost_file, index=False)

    try:
        pd.read_csv(found_file)
    except FileNotFoundError:
        # Create a new file for found items with required columns
        pd.DataFrame(columns=["description", "location", "date"]).to_csv(found_file, index=False)

# This function allows the user to register a lost item
# It collects input and saves it into the lost_items.csv file
def register_lost():
    description = simpledialog.askstring("Register Lost Item", "Item description:")
    if not description:
        return
    location = simpledialog.askstring("Register Lost Item", "Where was it lost?:")
    if not location:
        return
    current_date = get_current_datetime()
    date = simpledialog.askstring("Register Lost Item", "Date:", initialvalue=current_date or "")
    if not date:
        return
    matricula = simpledialog.askstring("Register Lost Item", "Student ID:")
    if not matricula:
        return

    # Load existing data
    df = pd.read_csv(lost_file)

    # Create a new row with user input
    new_item = pd.DataFrame([[description, location, date, matricula]], columns=df.columns)

    # Append the new row to the existing data
    df = pd.concat([df, new_item], ignore_index=True)

    # Save updated data back to CSV
    df.to_csv(lost_file, index=False)

    messagebox.showinfo("Success", "Lost item registered!")

# This function allows the user to register a found item
def register_found():
    description = simpledialog.askstring("Register Found Item", "Item description:")
    if not description:
        return
    location = simpledialog.askstring("Register Found Item", "Where was it found?:")
    if not location:
        return
    current_date = get_current_datetime()
    date = simpledialog.askstring("Register Found Item", "Date:", initialvalue=current_date or "")
    if not date:
        return

    # Load existing found items
    df = pd.read_csv(found_file)

    # Create new row
    new_item = pd.DataFrame([[description, location, date]], columns=df.columns)

    # Append and save
    df = pd.concat([df, new_item], ignore_index=True)
    df.to_csv(found_file, index=False)

    messagebox.showinfo("Success", "Found item registered!")

# This function allows the user to delete lost or found items in a combined window with tabs
def delete_items():
    try:
        lost_df = pd.read_csv(lost_file)
        found_df = pd.read_csv(found_file)
        
        if len(lost_df) == 0 and len(found_df) == 0:
            messagebox.showwarning("No Items", "No items to delete.")
            return
        
        # Create a new window for deleting items
        delete_window = tk.Toplevel()
        delete_window.title("Delete Items")
        delete_window.geometry("800x450")
        
        # Create notebook (tabs)
        notebook = ttk.Notebook(delete_window)
        notebook.pack(fill=tk.BOTH, expand=True, padx=10, pady=10)
        
        # TAB 1: Delete Lost Items
        lost_frame = ttk.Frame(notebook)
        notebook.add(lost_frame, text="Delete Lost Items")
        
        # Title
        title_label = ttk.Label(lost_frame, text="Select a lost item to delete:", 
                                font=("Arial", 12, "bold"))
        title_label.pack(anchor='w', padx=10, pady=(10, 10))
        
        if len(lost_df) == 0:
            no_items_label = ttk.Label(lost_frame, text="No lost items to delete.", 
                                       font=("Arial", 11))
            no_items_label.pack(anchor='w', padx=10, pady=20)
        else:
            # Create Treeview for lost items
            lost_tree = ttk.Treeview(lost_frame, height=12, columns=("ID", "Description", "Location", "Date"), 
                                     show="headings")
            lost_tree.column("ID", width=50)
            lost_tree.column("Description", width=300)
            lost_tree.column("Location", width=200)
            lost_tree.column("Date", width=150)
            
            lost_tree.heading("ID", text="ID")
            lost_tree.heading("Description", text="Description")
            lost_tree.heading("Location", text="Location")
            lost_tree.heading("Date", text="Date")
            
            # Add items to tree
            for idx, row in lost_df.iterrows():
                lost_tree.insert("", tk.END, values=(idx, row['description'], row['location'], row['date']))
            
            lost_tree.pack(fill=tk.BOTH, expand=True, padx=10, pady=(0, 10))
            
            # Button frame for lost items
            lost_button_frame = ttk.Frame(lost_frame)
            lost_button_frame.pack(fill=tk.X, padx=10, pady=10)
            
            def delete_lost_selected():
                selection = lost_tree.selection()
                if not selection:
                    messagebox.showwarning("No Selection", "Please select an item to delete.")
                    return
                
                item = lost_tree.item(selection[0])
                item_id = int(item['values'][0])
                item_desc = item['values'][1]
                
                if messagebox.askyesno("Confirm Delete", f"Delete '{item_desc}'?"):
                    df_updated = pd.read_csv(lost_file)
                    df_updated = df_updated.drop(item_id).reset_index(drop=True)
                    df_updated.to_csv(lost_file, index=False)
                    messagebox.showinfo("Success", f"Deleted lost item: {item_desc}")
                    lost_tree.delete(selection[0])
            
            ttk.Button(lost_button_frame, text="Delete Selected", command=delete_lost_selected).pack(side=tk.LEFT, padx=5)
        
        # TAB 2: Delete Found Items
        found_frame = ttk.Frame(notebook)
        notebook.add(found_frame, text="Delete Found Items")
        
        # Title
        title_label2 = ttk.Label(found_frame, text="Select a found item to delete:", 
                                 font=("Arial", 12, "bold"))
        title_label2.pack(anchor='w', padx=10, pady=(10, 10))
        
        if len(found_df) == 0:
            no_items_label2 = ttk.Label(found_frame, text="No found items to delete.", 
                                        font=("Arial", 11))
            no_items_label2.pack(anchor='w', padx=10, pady=20)
        else:
            # Create Treeview for found items
            found_tree = ttk.Treeview(found_frame, height=12, columns=("ID", "Description", "Location", "Date"), 
                                      show="headings")
            found_tree.column("ID", width=50)
            found_tree.column("Description", width=300)
            found_tree.column("Location", width=200)
            found_tree.column("Date", width=150)
            
            found_tree.heading("ID", text="ID")
            found_tree.heading("Description", text="Description")
            found_tree.heading("Location", text="Location")
            found_tree.heading("Date", text="Date")
            
            # Add items to tree
            for idx, row in found_df.iterrows():
                found_tree.insert("", tk.END, values=(idx, row['description'], row['location'], row['date']))
            
            found_tree.pack(fill=tk.BOTH, expand=True, padx=10, pady=(0, 10))
            
            # Button frame for found items
            found_button_frame = ttk.Frame(found_frame)
            found_button_frame.pack(fill=tk.X, padx=10, pady=10)
            
            def delete_found_selected():
                selection = found_tree.selection()
                if not selection:
                    messagebox.showwarning("No Selection", "Please select an item to delete.")
                    return
                
                item = found_tree.item(selection[0])
                item_id = int(item['values'][0])
                item_desc = item['values'][1]
                
                if messagebox.askyesno("Confirm Delete", f"Delete '{item_desc}'?"):
                    df_updated = pd.read_csv(found_file)
                    df_updated = df_updated.drop(item_id).reset_index(drop=True)
                    df_updated.to_csv(found_file, index=False)
                    messagebox.showinfo("Success", f"Deleted found item: {item_desc}")
                    found_tree.delete(selection[0])
            
            ttk.Button(found_button_frame, text="Delete Selected", command=delete_found_selected).pack(side=tk.LEFT, padx=5)
        
        # Close button at bottom
        close_button_frame = ttk.Frame(delete_window)
        close_button_frame.pack(fill=tk.X, padx=10, pady=10)
        ttk.Button(close_button_frame, text="Close", command=delete_window.destroy).pack(side=tk.RIGHT)
    
    except Exception as e:
        messagebox.showerror("Error", f"Error deleting item: {e}")

