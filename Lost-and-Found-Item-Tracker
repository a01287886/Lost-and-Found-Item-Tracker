@app.route('/matches', methods=['GET'])
def get_matches():
    try:
        lost = pd.read_csv(lost_file)
        found = pd.read_csv(found_file)
        matches = []
        for l in lost["description"]:
            for f in found["description"]:
                if l.lower() in f.lower() or f.lower() in l.lower():
                    matches.append({"lost": l, "found": f})
        return jsonify(matches)
    except Exception as e:
        return jsonify({'error': str(e)}), 500

@app.route('/lost/<int:item_id>', methods=['DELETE'])
def delete_lost_item(item_id):
    try:
        df = pd.read_csv(lost_file)
        if 0 <= item_id < len(df):
            df = df.drop(item_id).reset_index(drop=True)
            df.to_csv(lost_file, index=False)
            return jsonify({'message': f'Lost item {item_id} deleted'}), 200
        else:
            return jsonify({'error': 'Item not found'}), 404
    except Exception as e:
        return jsonify({'error': str(e)}), 500

@app.route('/found/<int:item_id>', methods=['DELETE'])
