@app.route('/lost', methods=['POST'])
def add_lost():
    data = request.get_json()
    if not data or not all(k in data for k in ['description', 'location', 'date', 'matricula']):
        return jsonify({'error': 'Missing required fields'}), 400
    try:
        df = pd.read_csv(lost_file)
        new_item = pd.DataFrame([data])
        df = pd.concat([df, new_item], ignore_index=True)
        df.to_csv(lost_file, index=False)
        return jsonify({'message': 'Lost item added'}), 201
    except Exception as e:
        return jsonify({'error': str(e)}), 500

