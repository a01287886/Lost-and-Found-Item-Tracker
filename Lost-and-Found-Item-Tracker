# This function compares descriptions of lost and found items
# It tries to find possible matches based on similar text and displays them in a table
def match_items():
    lost = pd.read_csv(lost_file)
    found = pd.read_csv(found_file)

    matches = []
    match_count = 0
    # Compare each lost item with each found item
    for l in lost["description"]:
        for f in found["description"]:
            # If one description is contained in the other (case insensitive)
            if l.lower() in f.lower() or f.lower() in l.lower():
                matches.append({"lost": l, "found": f})
                match_count += 1

    # Create a new window for displaying matches
    match_window = tk.Toplevel()
    match_window.title("Item Matches")
    match_window.geometry("800x400")

    # Main frame
    main_frame = ttk.Frame(match_window)
    main_frame.pack(fill=tk.BOTH, expand=True, padx=10, pady=10)

    # Title with match count
    title_label = ttk.Label(main_frame, text=f"Possible Matches Found: {match_count}", 
                            font=("Arial", 14, "bold"))
    title_label.pack(anchor='w', pady=(0, 15))

    if match_count == 0:
        no_matches_label = ttk.Label(main_frame, text="No matches found.", 
                                     font=("Arial", 11))
        no_matches_label.pack(anchor='w', pady=20)
    else:
        # Create Treeview for matches
        match_tree = ttk.Treeview(main_frame, height=15, columns=("Lost Item", "Found Item"), 
                                  show="headings")
        match_tree.column("Lost Item", width=350)
        match_tree.column("Found Item", width=350)

        match_tree.heading("Lost Item", text="Lost Item")
        match_tree.heading("Found Item", text="Found Item")

        # Add matches to tree
        for idx, match in enumerate(matches):
            match_tree.insert("", tk.END, values=(match["lost"], match["found"]))

        match_tree.pack(fill=tk.BOTH, expand=True)

# GUI setup
def main():
    initialize_files()

    root = tk.Tk()
    root.title("Lost & Found Tracker")
    root.geometry("400x450")
    root.configure(bg='#f0f0f0')

    # Set modern theme
    style = ttk.Style()
    style.theme_use('clam')

    # Configure styles
    style.configure('TLabel', font=('Arial', 16, 'bold'), background='#f0f0f0', foreground='#333')
    style.configure('TButton', font=('Arial', 12), padding=10, relief='flat', background='#4CAF50', foreground='white')
    style.map('TButton', background=[('active', '#45a049')])

    # Title
    title_label = ttk.Label(root, text="Lost & Found Tracker")
    title_label.pack(pady=20)

    # Buttons
    button_frame = ttk.Frame(root)
    button_frame.pack(pady=10)

    ttk.Button(button_frame, text="Register Lost Item", command=register_lost).pack(fill='x', pady=5)
    ttk.Button(button_frame, text="Register Found Item", command=register_found).pack(fill='x', pady=5)
    ttk.Button(button_frame, text="View Items", command=view_items).pack(fill='x', pady=5)
    ttk.Button(button_frame, text="Match Items", command=match_items).pack(fill='x', pady=5)
    ttk.Button(button_frame, text="Delete Items", command=delete_items).pack(fill='x', pady=5)
    ttk.Button(button_frame, text="Exit", command=root.quit, style='Exit.TButton').pack(fill='x', pady=5)

    # Configure exit button differently
    style.configure('Exit.TButton', background='#f44336')
    style.map('Exit.TButton', background=[('active', '#d32f2f')])

    root.mainloop()

if __name__ == "__main__":
    initialize_files()
    # Start Flask API in a separate thread
    api_thread = Thread(target=lambda: app.run(debug=True, use_reloader=False, port=5000))
    api_thread.daemon = True
    api_thread.start()
    # Start GUI
    main()
